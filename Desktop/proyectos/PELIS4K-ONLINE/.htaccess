<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Handle React routes
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteRule . /index.html [L]
</IfModule>

# Bloquear URLs de anuncios conocidas
<FilesMatch "\.(php|html|js)$">
    SetEnvIfNoCase Referer "^http://([^.]+\.)*?ads\." block_ref=1
    SetEnvIfNoCase Referer "^http://([^.]+\.)*?pop\." block_ref=1
    SetEnvIfNoCase Referer "^http://([^.]+\.)*?click\." block_ref=1
    Order Allow,Deny
    Allow from all
    Deny from env=block_ref
</FilesMatch>

# Protection adicional
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_value allow_url_fopen On
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
