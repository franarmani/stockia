NODE_ENV=production
PORT=3000
API_URL=https://api.tuturno.app

# Database (será llenado por Railway)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_DATABASE=tuturno

# JWT
JWT_SECRET=generate_a_random_secret_key_minimum_32_characters_long_for_security
JWT_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

# Frontend
FRONTEND_URL=https://tuturno.app

# Logging
LOG_LEVEL=info

# Optional: Payment (cuando esté listo)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Optional: Email
SENDGRID_API_KEY=

# Optional: SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
