# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=turnos_user
DB_PASSWORD=turnos_password
DB_NAME=turnos_dev
DATABASE_URL=postgresql://turnos_user:turnos_password@localhost:5432/turnos_dev

# Redis
REDIS_URL=redis://localhost:6379

# Backend
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Frontend Port
FRONTEND_PORT=3001

# Payments (MercadoPago)
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=test_key
MERCADO_PAGO_ACCESS_TOKEN=test_token

# Email (if using service)
SENDGRID_API_KEY=your_sendgrid_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AWS S3 (for logo uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=turnos-uploads

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn
