{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(index.html|sw.js|manifest.webmanifest|manifest.json|version.json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, proxy-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "stockia-two.vercel.app" }],
      "destination": "https://stockia-main.vercel.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/supabase-api/:path*", "destination": "https://mrpenblsmooeqzegtcqp.supabase.co/:path*" },
    { "source": "/((?!assets/|supabase-api/).*)", "destination": "/index.html" }
  ]
}
