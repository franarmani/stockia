# STOCKIA Billing Service — Environment
# Copy to .env and fill in values

# Port
PORT=3001

# Service authentication key (shared with Supabase Edge Functions)
BILLING_SERVICE_KEY=your-secret-key-here

# Encryption key for private keys (same as FISCAL_ENC_KEY in Supabase Edge Functions)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FISCAL_ENC_KEY=<hex string>
